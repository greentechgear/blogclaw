# BlogClaw - Environment Variables
# Copy this to .env and fill in your values

# WordPress Site 1 (primary blog)
WORDPRESS_URL=https://yoursite.com
WORDPRESS_USERNAME=admin
WORDPRESS_PASSWORD=your-application-password-here

# WordPress Site 2 (optional, for multi-site analysis)
# WORDPRESS_URL_2=https://othersite.com
# WORDPRESS_USERNAME_2=admin
# WORDPRESS_PASSWORD_2=your-other-app-password-here

# Google Gemini (for infographic generation, optional)
# GOOGLE_AI_API_KEY=your-gemini-api-key
